<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Welcome Screen -->
        <LinearLayout
            android:id="@+id/welcome_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌨️"
                android:textSize="64sp"
                android:layout_marginTop="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simple Rade Keyboard"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This is a passion project of mine to make \na keyboard for the Rade language with \ntone marks and smart typing features"
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/next_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Get Started"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_button"
                android:layout_marginTop="48dp" />

        </LinearLayout>

        <!-- Step 1: Enable Keyboard -->
        <LinearLayout
            android:id="@+id/step1_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 1 of 3"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable Rade Keyboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <ImageView
                    android:id="@+id/step1_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/step1_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏳ Tap 'Enable Keyboard' below"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This will open Android's keyboard settings.\n\n📱 Look for 'Rade Keyboard' in the list\n✅ Turn it ON\n↩️ Come back to this app"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/enable_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Keyboard"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_button"
                android:layout_marginTop="32dp" />

        </LinearLayout>

        <!-- Step 2: Select Default -->
        <LinearLayout
            android:id="@+id/step2_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 2 of 3"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Rade Keyboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <ImageView
                    android:id="@+id/step2_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/step2_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏳ Tap 'Select Keyboard' below"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now make Rade Keyboard your active keyboard.\n\n📱 Choose 'Rade Keyboard' from the keyboard picker\n⌨️ Or long-press the space bar to switch\n🔄 You can also pull down notifications and tap the keyboard icon"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/select_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Keyboard Picker"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_button"
                android:layout_marginTop="32dp" />

        </LinearLayout>

        <!-- Step 3: Test -->
        <LinearLayout
            android:id="@+id/step3_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 3 of 3"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test Your Keyboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <ImageView
                    android:id="@+id/step3_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/step3_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ready to test!"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Congratulations! You're ready to go!"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_green_dark"
                android:layout_marginTop="24dp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/rounded_edittext"
                android:gravity="top|start"
                android:hint="Test your Rade keyboard here: áêíôúýăâêôơư"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Try typing vowels and long-pressing for tone marks!\n📝 Double-tap Shift for caps lock\n🔙 Hold delete key to delete whole words"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- Complete Screen -->
        <LinearLayout
            android:id="@+id/complete_screen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="64sp"
                android:layout_marginTop="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Set!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rade Keyboard is now ready to use.\nEnjoy typing in Vietnamese!"
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/finish_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Start Typing!"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_button"
                android:layout_marginTop="48dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>