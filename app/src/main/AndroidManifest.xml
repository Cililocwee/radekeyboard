<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Key-press haptics; the feature is opt-in (off by default) in keyboard settings. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/rade_icon"
        android:label="@string/app_name"
        android:roundIcon="@drawable/rade_icon"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:exported="true"
            android:name="com.corriestroup.radekeyboard.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Add the new OnboardingActivity -->
        <activity
            android:exported="false"
            android:name="com.corriestroup.radekeyboard.OnboardingActivity"
            android:theme="@style/AppTheme" />

        <service
            android:name="com.corriestroup.radekeyboard.ModernInputMethodService"
            android:exported="true"
            android:enabled="true"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter android:priority="0">
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>